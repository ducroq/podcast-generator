---
import AudioPlayer from './AudioPlayer.astro';
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        Built with AI
      </span>
    </div>

    <h1 class="hero-title">
      AI-Generated Podcasts<br/>
      <span class="hero-highlight">That Sound Human</span>
    </h1>

    <p class="hero-subtitle">
      A methodology and production toolkit for creating multilingual podcasts
      with synthetic voices — developed by one person using AI-augmented workflows.
    </p>

    <div class="hero-player">
      <div class="hero-player-label">
        <span class="player-tag">Featured</span>
        Voice Demo &mdash; Felix, science narrator
      </div>
      <AudioPlayer src={`${base}audio/featured-demo.mp3`} label="Felix voice demo" />
    </div>

    <div class="hero-actions">
      <a href="https://github.com/ducroq/podcast-generator" class="btn btn-primary" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        View Source
      </a>
      <a href="#pipeline" class="btn btn-secondary">See the proof</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem 2rem;
    position: relative;
    overflow: hidden;
  }

  /* Subtle radial glow behind hero */
  .hero::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, var(--amber-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 720px;
    text-align: center;
    position: relative;
  }

  .hero-badge {
    margin-bottom: 1.5rem;
  }

  .hero-title {
    margin-bottom: 1.5rem;
  }

  .hero-highlight {
    color: var(--amber);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    line-height: 1.7;
    margin: 0 auto 2.5rem;
    max-width: 580px;
  }

  .hero-player {
    max-width: 520px;
    margin: 0 auto 2.5rem;
  }

  .hero-player-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
    justify-content: center;
  }

  .player-tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--amber);
    background: var(--amber-glow);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--amber);
    color: var(--bg);
  }
  .btn-primary:hover {
    background: var(--text);
    color: var(--bg);
    box-shadow: 0 0 24px var(--amber-glow-strong);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover {
    border-color: var(--amber-dim);
    color: var(--text);
  }
</style>
