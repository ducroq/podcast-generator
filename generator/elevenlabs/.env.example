# ElevenLabs API Configuration
ELEVENLABS_API_KEY=your_api_key_here

# Voice IDs for different speakers (get these from ElevenLabs dashboard)
# Go to https://elevenlabs.io/app/voice-library to find voice IDs
# Format: VOICE_SPEAKER_NAME=voice_id

# Main podcast hosts
VOICE_EMMA=voice_id_here
VOICE_LUCAS=voice_id_here

# Additional speakers
VOICE_PIET=voice_id_here

# Language variants (used with --lang flag)
# Suffix matches the language code: _DE for German, _EN for English, etc.
VOICE_EMMA_DE=voice_id_here
VOICE_LUCAS_DE=voice_id_here
VOICE_PIET_DE=voice_id_here
